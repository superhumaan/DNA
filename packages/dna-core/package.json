{
  "name": "@superhumaan/dna-core",
  "version": "0.1.0",
  "private": true,
  "description": "DNA core — scanner, generators, wizard, validation",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "assets"],
  "scripts": {
    "build": "tsup && node ../../scripts/generate-catalog-assets.mjs",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@superhumaan/dna-config": "workspace:*",
    "@superhumaan/dna-github": "workspace:*",
    "@superhumaan/dna-templates": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  },
  "license": "MIT"
}
