{
  "name": "@superhumaan/dna-by-humaan",
  "version": "0.4.5",
  "description": "DNA by Humaan — open-source project brain, 768-pack knowledge marketplace, tiered compliance (GDPR/HIPAA/ISO/SOC2), runtime observer, and AI-assisted repair for TypeScript teams",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/superhumaan/DNA.git",
    "directory": "packages/dna-cli"
  },
  "homepage": "https://dna.humaan.app",
  "bugs": {
    "url": "https://github.com/superhumaan/DNA/issues"
  },
  "type": "module",
  "bin": {
    "dna": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.js"
    },
    "./runtime/preload": {
      "import": "./dist/runtime-preload.js"
    }
  },
  "files": [
    "dist",
    "assets",
    "README.md",
    "SPONSORS.md",
    "CREDITS.md"
  ],
  "scripts": {
    "build": "rm -rf dist && tsup && node scripts/copy-assets.mjs",
    "dev": "NODE_OPTIONS='--import @superhumaan/dna-by-humaan/runtime/preload' tsup src/index.ts --format esm --dts --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "docker:build": "docker build -t dna-app:local .",
    "docker:verify": "docker build -t dna-app:local . && docker run --rm dna-app:local node -e \"console.log('ok')\""
  },
  "devDependencies": {
    "@superhumaan/dna-ai": "workspace:*",
    "@superhumaan/dna-config": "workspace:*",
    "@superhumaan/dna-core": "workspace:*",
    "@superhumaan/dna-github": "workspace:*",
    "@superhumaan/dna-immune": "workspace:*",
    "@superhumaan/dna-runtime": "workspace:*",
    "@superhumaan/dna-templates": "workspace:*",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  },
  "peerDependencies": {
    "express": "^4.18.0",
    "fastify": "^4.0.0 || ^5.0.0",
    "@nestjs/common": "^10.0.0 || ^11.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    },
    "fastify": {
      "optional": true
    },
    "@nestjs/common": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=20"
  },
  "author": "Humaan by Superlite",
  "keywords": [
    "dna",
    "humaan",
    "project-intelligence",
    "ai-context",
    "cursor",
    "copilot",
    "claude",
    "cli",
    "typescript",
    "runtime",
    "observability",
    "knowledge-packs",
    "marketplace",
    "compliance",
    "gdpr",
    "hipaa",
    "iso27001",
    "soc2",
    "healthcare",
    "fhir",
    "express",
    "nextjs",
    "fastify",
    "nestjs",
    "github-automation",
    "ai-repair",
    "devtools"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/superhumaan"
  },
  "contributors": []
}
