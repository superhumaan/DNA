{
  "name": "@superhumaan/dna-runtime",
  "version": "0.1.2",
  "private": true,
  "description": "DNA by Humaan — runtime observer for Node.js applications",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@superhumaan/dna-ai": "workspace:*",
    "@superhumaan/dna-config": "workspace:*",
    "@superhumaan/dna-feedback": "workspace:*",
    "@superhumaan/dna-github": "workspace:*",
    "@superhumaan/dna-immune": "workspace:*",
    "@types/express": "^5.0.0",
    "express": "^4.21.2",
    "fastify": "^5.2.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  },
  "peerDependencies": {
    "express": "^4.18.0",
    "fastify": "^4.0.0 || ^5.0.0",
    "@nestjs/common": "^10.0.0 || ^11.0.0"
  },
  "peerDependenciesMeta": {
    "express": { "optional": true },
    "fastify": { "optional": true },
    "@nestjs/common": { "optional": true }
  },
  "license": "MIT"
}
